{
	"name": "@clay-cms/db-libsql",
	"version": "0.0.0",
	"description": "libSQL / Turso database adapter for Clay CMS",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/reeple-studio/clay-cms.git",
		"directory": "packages/db-libsql"
	},
	"homepage": "https://clay-cms.reeple.studio",
	"bugs": "https://github.com/reeple-studio/clay-cms/issues",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "tsup --watch",
		"build": "tsup",
		"prepublishOnly": "pnpm build"
	},
	"keywords": [
		"astro",
		"clay-cms",
		"libsql",
		"turso",
		"sqlite",
		"database"
	],
	"license": "MIT",
	"peerDependencies": {
		"clay-cms": "workspace:*"
	},
	"dependencies": {
		"@clay-cms/drizzle": "workspace:*",
		"@libsql/client": "^0.17.4",
		"drizzle-orm": "^0.45.2"
	},
	"devDependencies": {
		"@types/node": "^26.1.1",
		"tsup": "8.5.1",
		"typescript": "7.0.2"
	}
}
