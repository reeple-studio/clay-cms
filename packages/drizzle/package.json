{
	"name": "@clay-cms/drizzle",
	"version": "0.0.0",
	"description": "Drizzle ORM schema builder and CRUD helpers for Clay CMS",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "tsup --watch",
		"build": "tsup",
		"prepublishOnly": "pnpm build"
	},
	"keywords": [
		"clay-cms",
		"drizzle",
		"orm",
		"schema"
	],
	"license": "MIT",
	"peerDependencies": {
		"clay-cms": "workspace:*",
		"drizzle-orm": ">=0.38.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"better-sqlite3": "^12.9.0",
		"drizzle-orm": "^0.45.2",
		"tsup": "8.5.1",
		"typescript": "6.0.2"
	}
}
