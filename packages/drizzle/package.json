{
	"name": "@clay-cms/drizzle",
	"version": "0.0.0",
	"description": "Drizzle ORM schema builder and CRUD helpers for Clay CMS",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/reeple-studio/clay-cms.git",
		"directory": "packages/drizzle"
	},
	"homepage": "https://clay-cms.reeple.studio",
	"bugs": "https://github.com/reeple-studio/clay-cms/issues",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "tsup --watch",
		"build": "tsup",
		"prepublishOnly": "pnpm build"
	},
	"keywords": [
		"clay-cms",
		"drizzle",
		"orm",
		"schema"
	],
	"license": "MIT",
	"peerDependencies": {
		"clay-cms": "workspace:*",
		"drizzle-orm": ">=0.44.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"better-sqlite3": "^12.11.1",
		"drizzle-orm": "^0.45.2",
		"tsup": "8.5.1",
		"typescript": "6.0.3"
	}
}
