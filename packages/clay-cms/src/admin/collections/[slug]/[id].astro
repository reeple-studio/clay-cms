---
import { actions } from "astro:actions";
import cms from "virtual:clay-cms/api";
import config from "virtual:clay-cms/config";
import { AccessDeniedError, evaluateFieldAccess } from "clay-cms/access";

import FieldInput from "../../components/FieldInput.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const { collections } = config;
const { slug, id } = Astro.params;

const collection = collections.find((c) => c.slug === slug);

if (!collection) {
	return new Response(null, { status: 404, statusText: "Not Found" });
}

const user = Astro.locals.clayUser;

const singularLabel =
	collection.labels?.singular ??
	collection.slug.charAt(0).toUpperCase() + collection.slug.slice(1);

const pluralLabel =
	collection.labels?.plural ??
	collection.slug.charAt(0).toUpperCase() + collection.slug.slice(1);

// ? handle delete result — redirect on success
const deleteResult = Astro.getActionResult(actions.cms.deleteEntry);
if (deleteResult && !deleteResult.error) {
	return Astro.redirect(`/admin/collections/${slug}`);
}

// ? handle update result
const updateResult = Astro.getActionResult(actions.cms.updateEntry);
const updateError = updateResult?.error?.message;

// ? fetch the document via the raw cms — pass the current session user so the gate enforces against them
let document: Record<string, unknown> | null = null;
try {
	document = (await cms[slug!]!.findOne({
		id: id!,
		user,
	})) as Record<string, unknown> | null;
} catch (err) {
	if (err instanceof AccessDeniedError) {
		return new Response(null, { status: 403, statusText: "Forbidden" });
	}

	throw err;
}

if (!document) {
	return new Response(null, { status: 404, statusText: "Not Found" });
}

// ? pre-flight permission checks — hide buttons the current user can't act on
const canUpdate = await cms[slug!]!.can("update", {
	doc: document,
	user,
});

const canDelete = await cms[slug!]!.can("delete", {
	doc: document,
	user,
});

// ? determine editable fields (exclude system/upload/auth internals)
const systemFieldKeys = new Set([
	"id",
	"createdAt",
	"updatedAt",
	"filename",
	"mimeType",
	"filesize",
	"url",
	"width",
	"height",
	"hashedPassword",
]);

// ? per-field permissions snapshot — one walk, used for both hide-on-read
// ? and disable-on-update. The collection-level `canUpdate` above still
// ? gates the Save button; the per-field map adds field-by-field nuance.
const fieldPerms = await evaluateFieldAccess(collection, document, user);

const editableFields = Object.entries(collection.fields).filter(
	([key, field]) => {
		if (systemFieldKeys.has(key)) return false;
		if ("hidden" in field && field.hidden) return false;
		// ? read-denied → don't render the field at all
		const perms = fieldPerms.get(key);
		if (perms && !perms.canRead) return false;
		return true;
	},
);
---

<BaseLayout title={`Edit ${singularLabel} — Clay CMS`}>
	<div class="min-h-screen bg-neutral-950">
		<header
			class="border-b border-neutral-800 px-6 py-4 flex items-center justify-between"
		>
			<div class="flex items-center gap-3">
				<a
					href="/admin"
					class="text-neutral-400 hover:text-white transition-colors"
				>
					Clay CMS
				</a>

				<span class="text-neutral-600">/</span>

				<a
					href={`/admin/collections/${slug}`}
					class="text-neutral-400 hover:text-white transition-colors"
				>
					{pluralLabel}
				</a>

				<span class="text-neutral-600">/</span>

				<h1 class="text-lg font-semibold text-white">Edit</h1>
			</div>

			<div class="flex items-center gap-4">
				<span class="text-sm text-neutral-400">
					{user?.name ?? user?.email}
				</span>
			</div>
		</header>

		<main class="p-6 max-w-2xl">
			{
				updateResult && !updateResult.error && (
					<div class="mb-4 p-3 text-sm text-green-400 border border-green-900 rounded">
						Saved successfully.
					</div>
				)
			}

			{
				updateError && (
					<div class="mb-4 p-3 text-sm text-red-400 border border-red-900 rounded">
						{updateError}
					</div>
				)
			}

			{
				deleteResult?.error && (
					<div class="mb-4 p-3 text-sm text-red-400 border border-red-900 rounded">
						{deleteResult.error.message}
					</div>
				)
			}

			<form
				method="POST"
				action={actions.cms.updateEntry}
				class="flex flex-col gap-4"
			>
				<input type="hidden" name="_slug" value={slug} />
				<input type="hidden" name="_id" value={id} />

				{
					editableFields.map(([key, field]) => (
						<FieldInput
							name={key}
							field={field}
							value={document[key]}
							disabled={
								!canUpdate ||
								fieldPerms.get(key)?.canUpdate === false
							}
						/>
					))
				}

				<div class="flex items-center gap-3 mt-2">
					{
						canUpdate && (
							<button
								type="submit"
								class="px-4 py-2 bg-white text-black text-sm font-medium rounded hover:bg-neutral-200 transition-colors"
							>
								Save
							</button>
						)
					}
					<a
						href={`/admin/collections/${slug}`}
						class="px-4 py-2 text-sm text-neutral-400 hover:text-white transition-colors"
					>
						{canUpdate ? "Cancel" : "Back"}
					</a>
				</div>
			</form>

			{
				canDelete && (
					<div class="mt-12 pt-6 border-t border-neutral-800">
						<form method="POST" action={actions.cms.deleteEntry}>
							<input type="hidden" name="slug" value={slug} />
							<input type="hidden" name="id" value={id} />

							<button
								type="submit"
								class="px-4 py-2 text-sm text-red-400 border border-red-900 rounded hover:bg-red-950 transition-colors"
								onclick="return confirm('Are you sure you want to delete this entry?')"
							>
								Delete
							</button>
						</form>
					</div>
				)
			}
		</main>
	</div>
</BaseLayout>
