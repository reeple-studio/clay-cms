---
import BaseHead from "../components/BaseHead.astro";
import "../styles/styles.css";

export interface Props {
	title?: string;
}

const { title = "Clay CMS" } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title}>
			<slot name="head" slot="head" />
		</BaseHead>
	</head>

	<body>
		<slot />
	</body>
</html>
