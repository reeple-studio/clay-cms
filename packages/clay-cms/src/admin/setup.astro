---
import { actions } from "astro:actions";
import BaseLayout from "./layouts/BaseLayout.astro";

const result = Astro.getActionResult(actions.cms.setup);
const inputError = result?.error?.fields;
const serverError = result?.error?.message;

if (result && !result.error) {
	return Astro.redirect("/admin");
}
---

<BaseLayout title="Setup — Clay CMS">
	<div class="min-h-screen flex items-center justify-center bg-neutral-950">
		<div class="w-full max-w-sm p-6 border border-neutral-800 rounded-lg">
			<h1 class="text-xl font-semibold text-white mb-1">Clay CMS</h1>
			<p class="text-sm text-neutral-400 mb-6">
				Create your admin account to get started.
			</p>

			{
				serverError && (
					<div class="mb-4 p-3 text-sm text-red-400 border border-red-900 rounded">
						{serverError}
					</div>
				)
			}

			<form
				method="POST"
				action={actions.cms.setup}
				class="flex flex-col gap-4"
			>
				<div class="flex flex-col gap-1">
					<label for="name" class="text-sm text-neutral-300"
						>Name</label
					>
					<input
						type="text"
						id="name"
						name="name"
						required
						class="px-3 py-2 bg-neutral-900 border border-neutral-700 rounded text-white text-sm focus:outline-none focus:border-neutral-500"
					/>
					{
						inputError?.name && (
							<p class="text-xs text-red-400">
								{inputError.name}
							</p>
						)
					}
				</div>

				<div class="flex flex-col gap-1">
					<label for="email" class="text-sm text-neutral-300"
						>Email</label
					>
					<input
						type="email"
						id="email"
						name="email"
						required
						class="px-3 py-2 bg-neutral-900 border border-neutral-700 rounded text-white text-sm focus:outline-none focus:border-neutral-500"
					/>
					{
						inputError?.email && (
							<p class="text-xs text-red-400">
								{inputError.email}
							</p>
						)
					}
				</div>

				<div class="flex flex-col gap-1">
					<label for="password" class="text-sm text-neutral-300"
						>Password</label
					>
					<input
						type="password"
						id="password"
						name="password"
						required
						minlength="8"
						class="px-3 py-2 bg-neutral-900 border border-neutral-700 rounded text-white text-sm focus:outline-none focus:border-neutral-500"
					/>
					{
						inputError?.password && (
							<p class="text-xs text-red-400">
								{inputError.password}
							</p>
						)
					}
				</div>

				<button
					type="submit"
					class="mt-2 px-4 py-2 bg-white text-black text-sm font-medium rounded hover:bg-neutral-200 transition-colors"
				>
					Create account
				</button>
			</form>
		</div>
	</div>
</BaseLayout>
