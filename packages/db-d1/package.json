{
	"name": "@clay-cms/db-d1",
	"version": "0.0.0",
	"description": "Cloudflare D1 database adapter for Clay CMS",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/reeple-studio/clay-cms.git",
		"directory": "packages/db-d1"
	},
	"homepage": "https://clay-cms.reeple.studio",
	"bugs": "https://github.com/reeple-studio/clay-cms/issues",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "tsup --watch",
		"build": "tsup",
		"prepublishOnly": "pnpm build"
	},
	"keywords": [
		"astro",
		"clay-cms",
		"d1",
		"cloudflare",
		"database"
	],
	"license": "MIT",
	"peerDependencies": {
		"clay-cms": "workspace:*"
	},
	"dependencies": {
		"@clay-cms/drizzle": "workspace:*",
		"drizzle-orm": "^0.45.2"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260701.1",
		"tsup": "8.5.1",
		"typescript": "6.0.3"
	}
}
