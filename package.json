{
	"name": "root",
	"private": true,
	"packageManager": "pnpm@11.9.0",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"package:dev": "pnpm --filter clay-cms dev",
		"playground:dev": "pnpm --filter playground dev",
		"dev": "pnpm --stream -r -parallel dev",
		"clean": "rm -rf packages/*/dist playground/dist playground/.astro playground/.wrangler node_modules/.vite",
		"changeset": "changeset",
		"lint": "biome check .",
		"lint:fix": "biome check --write",
		"ci-version": "changeset version && pnpm install --no-frozen-lockfile",
		"test": "vitest run",
		"ci-publish": "changeset publish"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"@changesets/changelog-github": "0.7.0",
		"@changesets/cli": "2.31.1",
		"typescript": "7.0.2",
		"vitest": "^4.1.10"
	}
}
